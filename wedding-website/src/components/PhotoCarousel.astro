---
const images = [
    "/images/engagement-photos/IMG_1988.jpg",
    "/images/engagement-photos/IMG_1989.jpg",
    "/images/engagement-photos/IMG_1992.jpg",
    "/images/engagement-photos/IMG_2018.jpg",
    "/images/engagement-photos/IMG_2015.jpg",
    "/images/engagement-photos/IMG_2016.jpg",
    "/images/engagement-photos/IMG_1996.jpg",
    "/images/engagement-photos/IMG_1999.jpg",
    "/images/engagement-photos/IMG_2009.jpg",
    "/images/engagement-photos/IMG_2014.jpg",
];
---

<div class="frame">

    <img
        class="doily"
        src="/images/doily.png"
        alt=""
        aria-hidden="true"
    />

    <div class="photo-frame">
        <img
            id="carousel-image"
            src={images[0]}
            alt="Audrey and Andrew"
        />
    </div>

</div>

<script define:vars={{ images }}>
    let current = 0;

    const image = document.getElementById("carousel-image");

    setInterval(() => {
        setTimeout(() => {
            current = (current + 1) % images.length;
            image.src = images[current];
        }, 500);

    }, 3000);
</script>

<style>
.frame {
    position: relative;

    width: min(700px, 95vw);
    aspect-ratio: 1.65;

    display: flex;
    justify-content: center;
    align-items: center;

    margin: 2rem auto;
}

.doily {
    position: absolute;

    width: 100%;
    height: 100%;

    object-fit: contain;

    z-index: 0;

    pointer-events: none;
}

.photo-frame {
    position: relative;

    width: 82%;
    height: 85%;

    overflow: hidden;

    border-radius: 50%;

    z-index: 1;
}

.photo-frame img {
    width: 100%;
    height: 100%;

    object-fit: cover;
}
</style>